# react-scripts 5 predates React 19 and pins peer deps to React 18, and the
# TypeScript devDependency (4.9.5) conflicts with i18next's optional typescript@^5
# peer. legacy-peer-deps makes install/ci resolve consistently across local, CI,
# and the VPS build host. Remove this if/when the app migrates off CRA.
legacy-peer-deps=true
