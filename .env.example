# Ozma Kapa web — environment configuration.
#
# Copy to one of:
#   - .env.production            (baked into `npm run build`)
#   - .env.development.local     (used by `npm start`)
# All REACT_APP_* vars are baked in at BUILD time (Create React App), so rebuild
# after changing them. Values are read through src/config/env.js (single source of truth).

# ---- Required in production (build shows a loud config error if unset) ----
# API host (Django backend). No trailing slash.
REACT_APP_API_BASE_URL=
# Auth endpoint host (usually the same host as the API).
REACT_APP_AUTH_BASE_URL=

# ---- Optional API config ----
# Explicit auth API base (…/api/v1/auth_api). Derived from REACT_APP_AUTH_BASE_URL if unset.
REACT_APP_AUTH_API_BASE_URL=
# Extra failover API bases. Leave EMPTY in production unless you have real hosts
# (never point these at localhost/LAN in a production build).
REACT_APP_SECONDARY_API_BASE_URL=
REACT_APP_TERTIARY_API_BASE_URL=
# Prefer the local backend first when running on localhost (dev convenience only).
REACT_APP_LOCAL_BACKEND_FIRST=false
# HTTP client tuning.
REACT_APP_API_REQUEST_TIMEOUT_MS=15000
REACT_APP_API_ATTEMPTS_PER_BASE=1
REACT_APP_API_FAILOVER_DELAY_MS=200

# ---- OAuth ----
# Keep SSR disabled unless the backend exposes /<provider>/authorize/ssr/ endpoints.
REACT_APP_OAUTH_SSR=false
REACT_APP_OAUTH_RESULT_ONLY=false
# REACT_APP_OAUTH_SSR_TIMEOUT_MS=12000
# REACT_APP_OAUTH_SSR_PATH=/:provider/authorize/ssr/

# ---- Feature flags ----
# Managed (paid) LLM path via the backend chat_api proxy. Keep OFF until the
# backend chat_api + billing endpoints exist.
REACT_APP_ENABLE_MANAGED_LLM=false

# ---- BYO provider keys (optional dev fallbacks; end users normally enter their own) ----
# REACT_APP_GEMINI_SECRET_KEY=
# REACT_APP_OPENROUTER_SECRET_KEY=
# REACT_APP_OPENAI_SECRET_KEY=
# REACT_APP_HUGGINGFACE_SECRET_KEY=

# ---- Observability (optional) ----
# REACT_APP_SENTRY_DSN=
